DATABASE_URL=postgresql://events_user:events_pass@localhost:5432/events_db
REDIS_URL=redis://localhost:6379
STREAM_NAME=events:raw
DEAD_LETTER_STREAM=events:dead
CONSUMER_GROUP=workers
WORKER_BATCH_SIZE=10
WORKER_BLOCK_MS=1000
MAX_RETRIES=3
LAG_LIMIT=1000
PENDING_LIMIT=500
DEDUP_TTL=86400
STATUS_CACHE_TTL=3600
WORKER_METRICS_PORT=8001
