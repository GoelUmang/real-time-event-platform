FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir -e .

COPY app/ ./app/

EXPOSE 8000

# 4 Uvicorn workers saturates a 4-core M4 slice; tune via UVICORN_WORKERS env var.
CMD ["sh", "-c", "uvicorn app.api.main:app --host 0.0.0.0 --port 8000 --workers ${UVICORN_WORKERS:-4}"]
